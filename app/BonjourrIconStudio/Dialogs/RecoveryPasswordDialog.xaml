<Window x:Class="BonjourrIconStudio.Dialogs.RecoveryPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Защищённый профиль"
        Width="640" Height="450"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Padding="36">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText" Text="Восстановительный пароль" FontSize="26" FontWeight="SemiBold" />
            <TextBlock x:Name="DescriptionText" Grid.Row="1" Margin="0,10,0,24" Foreground="{StaticResource MutedTextBrush}" FontSize="15" TextWrapping="Wrap" LineHeight="23" />

            <StackPanel Grid.Row="2">
                <TextBlock Text="Пароль" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,7" />
                <PasswordBox x:Name="PasswordInput" FontSize="18" MinHeight="52" Padding="12,8" />
                <TextBlock x:Name="ConfirmationLabel" Text="Повторите пароль" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,7" />
                <PasswordBox x:Name="ConfirmationInput" FontSize="18" MinHeight="52" Padding="12,8" />
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" Margin="0,9,0,0" Visibility="Collapsed" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="Отмена" IsCancel="True" MinWidth="120" Margin="0,0,10,0" />
                <Button x:Name="ConfirmButton" Content="Продолжить" MinWidth="140" Style="{StaticResource PrimaryButton}" Click="Confirm_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
