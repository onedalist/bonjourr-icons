<Window x:Class="BonjourrIconStudio.Dialogs.RecoveryPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Защищённый профиль"
        Width="480" Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText" Text="Восстановительный пароль" FontSize="23" FontWeight="SemiBold" />
            <TextBlock x:Name="DescriptionText" Grid.Row="1" Margin="0,8,0,18" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" LineHeight="20" />

            <StackPanel Grid.Row="2">
                <PasswordBox x:Name="PasswordInput" />
                <PasswordBox x:Name="ConfirmationInput" Margin="0,10,0,0" />
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" Margin="0,9,0,0" Visibility="Collapsed" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="Отмена" IsCancel="True" Margin="0,0,8,0" />
                <Button x:Name="ConfirmButton" Content="Продолжить" Style="{StaticResource PrimaryButton}" Click="Confirm_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
